tion</th><th>Type</th><th>Entity</th><th>Protocol</th></tr></thead><tbody>\n    <tr><td style=\"color:#0F7173;\">outbound</td><td>governed_by</td><td>Cloud-Native Architecture Standard</td><td style=\"color:#94A3B8;\">—</td></tr>\n    <tr><td style=\"color:#94A3B8;\">inbound</td><td>container_of</td><td>Deployment Platform</td><td style=\"color:#94A3B8;\">—</td></tr><tr><td style=\"color:#94A3B8;\">inbound</td><td>uses</td><td>Deployment Pipeline</td><td style=\"color:#94A3B8;\">—</td></tr>\n    </tbody></table>\n  </div>\n  <h2>Compliance Status (0 findings)</h2><div class=\"section\">\n    <p style='color:#10B981;font-size:14px;'>No compliance findings</p>\n  </div>\n  <h2>Recent Signals (1)</h2><div class=\"section\"><div class=\"signal\"><strong style=\"font-size:14px;\">K8s Cluster — Node AutoScaling Triggered</strong><div style=\"color:#94A3B8;font-size:12px;margin-top:4px;\">AWS CloudWatch · medium</div><p style=\"font-size:13px;margin:8px 0 0 0;\">Karpenter triggered node autoscaling — added 4 m6i.2xlarge nodes to handle increased workload from month-end batch processing. Cluster utilization peaked at 82%. Nodes will scale down after 30 min idle.</p></div></div>\n  <div class=\"footer\">Generated by EAMS · 2026-04-02T05:40:19.029Z</div>\n</div></body></html>"
