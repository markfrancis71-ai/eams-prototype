  "scope_config": "{\"seed\":\"entity_id\",\"expand\":\"containers\"}",
  "include_rules": "[{\"rel_types\":[\"container_of\",\"uses\",\"stores_in\",\"reads_from\",\"publishes_to\",\"subscribes_to\"],\"kinds\":[\"container\",\"system\",\"actor\"]}]",
  "filters": "{}",
  "styling": "{\"nodeColors\":{\"container\":\"#0F7173\",\"system\":\"#1B3A5C\"}}",
  "layout": "{\"type\":\"hierarchical\",\"direction\":\"TB\"}",
  "output_config": "{\"format\":\"render-graph\"}",
  "version": "1.0"
}