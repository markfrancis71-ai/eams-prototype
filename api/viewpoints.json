[
  {
    "id": 1,
    "viewpoint_id": "viewpoint.c4-context",
    "name": "C4 System Context",
    "description": "Shows a system in its environment — actors, neighboring systems, and their interactions. The classic C4 Level 1 view.",
    "scope_strategy": "parameter-seed",
    "stakeholders": "[\"solution-architect\",\"engineering-manager\",\"cto\"]",
    "parameters": "{\"entity_id\":{\"type\":\"string\",\"description\":\"The system to center the view on\"}}",
    "scope_config": "{\"seed\":\"entity_id\",\"expand\":\"neighbors\"}",
    "include_rules": "[]",
    "filters": "{\"kinds\":[\"system\",\"actor\",\"container\"]}",
    "styling": "{\"nodeColors\":{\"system\":\"#1B3A5C\",\"actor\":\"#4A5568\"}}",
    "layout": "{\"type\":\"force-directed\",\"gravity\":0.3}",
    "output_config": "{\"format\":\"render-graph\"}",
    "version": "1.0"
  },
  {
    "id": 2,
    "viewpoint_id": "viewpoint.c4-container",
    "name": "C4 Container View",
    "description": "Shows the internal containers of a system — APIs, databases, message queues, UIs — and their relationships.",
    "scope_strategy": "parameter-seed",
    "stakeholders": "[\"solution-architect\",\"tech-lead\",\"developer\"]",
    "parameters": "{\"entity_id\":{\"type\":\"string\",\"description\":\"The system to show containers for\"}}",
    "scope_config": "{\"seed\":\"entity_id\",\"expand\":\"containers\"}",
    "include_rules": "[{\"rel_types\":[\"container_of\",\"uses\",\"stores_in\",\"reads_from\",\"publishes_to\",\"subscribes_to\"],\"kinds\":[\"container\",\"system\",\"actor\"]}]",
    "filters": "{}",
    "styling": "{\"nodeColors\":{\"container\":\"#0F7173\",\"system\":\"#1B3A5C\"}}",
    "layout": "{\"type\":\"hierarchical\",\"direction\":\"TB\"}",
    "output_config": "{\"format\":\"render-graph\"}",
    "version": "1.0"
  },
  {
    "id": 3,
    "viewpoint_id": "viewpoint.capability-map",
    "name": "Capability Heat Map",
    "description": "Maps business capabilities to the systems and processes that realize them. Heat-colored by maturity or risk.",
    "scope_strategy": "domain-query",
    "stakeholders": "[\"enterprise-architect\",\"business-analyst\",\"cto\"]",
    "parameters": "{\"domain\":{\"type\":\"string\"}}",
    "scope_config": "{\"query\":{\"kinds\":[\"capability\",\"system\",\"process\"]}}",
    "include_rules": "[{\"rel_types\":[\"realized_by\",\"supported_by\"]}]",
    "filters": "{\"kinds\":[\"capability\",\"system\",\"process\",\"goal\"]}",
    "styling": "{}",
    "layout": "{\"type\":\"grid\",\"columns\":3}",
    "output_config": "{\"format\":\"render-graph\"}",
    "version": "1.0"
  },
  {
    "id": 4,
    "viewpoint_id": "viewpoint.blast-radius",
    "name": "Blast Radius",
    "description": "Shows the impact radius of a system failure — all directly and transitively dependent systems, capabilities, and processes.",
    "scope_strategy": "parameter-seed",
    "stakeholders": "[\"solution-architect\",\"sre\",\"risk-officer\"]",
    "parameters": "{\"entity_id\":{\"type\":\"string\"}}",
    "scope_config": "{\"seed\":\"entity_id\",\"expand\":\"dependents\",\"depth\":3}",
    "include_rules": "[{\"rel_types\":[\"uses\",\"consumes\",\"subscribes_to\",\"reads_from\",\"realized_by\"]}]",
    "filters": "{}",
    "styling": "{\"emphasize_criticality\":true}",
    "layout": "{\"type\":\"radial\",\"center\":\"seed\"}",
    "output_config": "{\"format\":\"render-graph\"}",
    "version": "1.0"
  },
  {
    "id": 5,
    "viewpoint_id": "viewpoint.domain-interactions",
    "name": "Domain Interaction Map",
    "description": "Shows how domains interact through their systems. Cross-domain dependencies and integration points.",
    "scope_strategy": "entity-query",
    "stakeholders": "[\"enterprise-architect\",\"domain-architect\"]",
    "parameters": "{}",
    "scope_config": "{\"query\":{\"kinds\":[\"system\"]}}",
    "include_rules": "[]",
    "filters": "{\"kinds\":[\"system\"]}",
    "styling": "{}",
    "layout": "{\"type\":\"force-directed\",\"groupBy\":\"domain\"}",
    "output_config": "{\"format\":\"render-graph\"}",
    "version": "1.0"
  },
  {
    "id": 6,
    "viewpoint_id": "viewpoint.integration-surface",
    "name": "System Integration Surface",
    "description": "Shows all integration points for a system — incoming and outgoing APIs, events, and data flows.",
    "scope_strategy": "parameter-seed",
    "stakeholders": "[\"integration-architect\",\"tech-lead\"]",
    "parameters": "{\"entity_id\":{\"type\":\"string\"}}",
    "scope_config": "{\"seed\":\"entity_id\",\"expand\":\"all-connections\"}",
    "include_rules": "[{\"rel_types\":[\"uses\",\"consumes\",\"publishes_to\",\"subscribes_to\",\"invokes\"]}]",
    "filters": "{}",
    "styling": "{\"highlight_protocols\":true}",
    "layout": "{\"type\":\"force-directed\"}",
    "output_config": "{\"format\":\"render-graph\"}",
    "version": "1.0"
  },
  {
    "id": 7,
    "viewpoint_id": "viewpoint.tier1-dependency",
    "name": "Tier-1 Dependency Graph",
    "description": "Shows all tier-1 critical systems and their dependencies. Highlights single points of failure.",
    "scope_strategy": "entity-query",
    "stakeholders": "[\"enterprise-architect\",\"cto\",\"sre\"]",
    "parameters": "{}",
    "scope_config": "{\"query\":{\"criticality\":\"tier-1\"}}",
    "include_rules": "[{\"rel_types\":[\"uses\",\"stores_in\",\"reads_from\"]}]",
    "filters": "{\"criticality\":[\"tier-1\"]}",
    "styling": "{\"emphasize_criticality\":true}",
    "layout": "{\"type\":\"force-directed\"}",
    "output_config": "{\"format\":\"render-graph\"}",
    "version": "1.0"
  }
]